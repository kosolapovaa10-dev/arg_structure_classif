      "cell_type": "code",
      "source": [
        "from scipy.special import softmax\n",
        "from sklearn.metrics import classification_report, confusion_matrix, accuracy_score, precision_recall_fscore_support\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "import numpy as np\n",
        "\n",
        "# ВРУЧНУЮ меняешь здесь\n",
        "manual_threshold = 0.4\n",
        "\n",
        "# Предсказания на test\n",
        "test_output_mbert = trainer_weighted_mbert.predict(test_tok_mbert)\n",
        "\n",
        "y_true_mbert = test_output_mbert.label_ids\n",
        "test_probs_mbert = softmax(test_output_mbert.predictions, axis=1)\n",
        "\n",
        "attack_id = label2id[\"Attack\"]\n",
        "support_id = label2id[\"Support\"]\n",
        "\n",
        "attack_probs_test_mbert = test_probs_mbert[:, attack_id]\n",
        "\n",
        "y_pred_mbert = np.where(\n",
        "    attack_probs_test_mbert >= manual_threshold,\n",
        "    attack_id,\n",
        "    support_id\n",
        ")\n",
        "\n",
        "print(f\"Manual threshold for mBERT: {manual_threshold:.2f}\\n\")\n",
        "\n",
        "print(\"Classification report for mBERT:\\n\")\n",
        "print(classification_report(\n",
        "    y_true_mbert,\n",
        "    y_pred_mbert,\n",
        "    target_names=[id2label[i] for i in range(len(id2label))],\n",
        "    digits=4,\n",
        "    zero_division=0\n",
        "))\n",
        "\n",
        "precision_arr_mbert, recall_arr_mbert, f1_arr_mbert, _ = precision_recall_fscore_support(\n",
        "    y_true_mbert,\n",
        "    y_pred_mbert,\n",
        "    labels=[attack_id, support_id],\n",
        "    zero_division=0\n",
        ")\n",
        "\n",
        "mbert_summary_metrics_manual = {\n",
        "    \"accuracy\": accuracy_score(y_true_mbert, y_pred_mbert),\n",
        "    \"attack_precision\": precision_arr_mbert[0],\n",
        "    \"attack_recall\": recall_arr_mbert[0],\n",
        "    \"attack_f1\": f1_arr_mbert[0],\n",
        "    \"support_precision\": precision_arr_mbert[1],\n",
        "    \"support_recall\": recall_arr_mbert[1],\n",
        "    \"support_f1\": f1_arr_mbert[1],\n",
        "    \"macro_f1\": (f1_arr_mbert[0] + f1_arr_mbert[1]) / 2,\n",
        "    \"threshold\": manual_threshold\n",
        "}\n",
        "\n",
        "print(\"Summary metrics for mBERT:\")\n",
        "print(mbert_summary_metrics_manual)\n",
        "\n",
        "cm_mbert = confusion_matrix(y_true_mbert, y_pred_mbert)\n",
        "\n",
        "plt.figure(figsize=(5, 4))\n",
        "sns.heatmap(\n",
        "    cm_mbert,\n",
        "    annot=True,\n",
        "    fmt=\"d\",\n",
        "    cmap=sns.light_palette(\"pink\", as_cmap=True),\n",
        "    xticklabels=[\"Attack\", \"Support\"],\n",
        "    yticklabels=[\"Attack\", \"Support\"]\n",
        ")\n",
        "plt.xlabel(\"Predicted\")\n",
        "plt.ylabel(\"True\")\n",
        "plt.title(f\"mBERT Confusion Matrix, threshold = {manual_threshold:.2f}\")\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
