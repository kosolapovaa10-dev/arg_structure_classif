      "cell_type": "code",
      "source": [
        "from scipy.special import softmax\n",
        "from sklearn.metrics import precision_recall_fscore_support, accuracy_score\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "\n",
        "# Предсказания на validation\n",
        "val_output_mbert = trainer_weighted_mbert.predict(val_tok_mbert)\n",
        "\n",
        "y_val_true_mbert = val_output_mbert.label_ids\n",
        "val_probs_mbert = softmax(val_output_mbert.predictions, axis=1)\n",
        "\n",
        "attack_id = label2id[\"Attack\"]\n",
        "support_id = label2id[\"Support\"]\n",
        "\n",
        "attack_probs_mbert = val_probs_mbert[:, attack_id]\n",
        "\n",
        "results_mbert = []\n",
        "thresholds = np.arange(0.1, 0.91, 0.05)\n",
        "\n",
        "for threshold in thresholds:\n",
        "    y_val_pred_mbert = np.where(\n",
        "        attack_probs_mbert >= threshold,\n",
        "        attack_id,\n",
        "        support_id\n",
        "    )\n",
        "\n",
        "    precision_arr, recall_arr, f1_arr, _ = precision_recall_fscore_support(\n",
        "        y_val_true_mbert,\n",
        "        y_val_pred_mbert,\n",
        "        labels=[attack_id, support_id],\n",
        "        zero_division=0\n",
        "    )\n",
        "\n",
        "    acc = accuracy_score(y_val_true_mbert, y_val_pred_mbert)\n",
        "\n",
        "    results_mbert.append({\n",
        "        \"threshold\": threshold,\n",
        "        \"accuracy\": acc,\n",
        "        \"attack_precision\": precision_arr[0],\n",
        "        \"attack_recall\": recall_arr[0],\n",
        "        \"attack_f1\": f1_arr[0],\n",
        "        \"support_precision\": precision_arr[1],\n",
        "        \"support_recall\": recall_arr[1],\n",
        "        \"support_f1\": f1_arr[1],\n",
        "        \"macro_f1\": (f1_arr[0] + f1_arr[1]) / 2\n",
        "    })\n",
        "\n",
        "threshold_df_mbert = pd.DataFrame(results_mbert).sort_values(\n",
        "    [\"attack_f1\", \"attack_precision\"],\n",
        "    ascending=False\n",
        ")\n",
        "\n",
        "print(\"Top thresholds for mBERT on validation:\")\n",
        "display(threshold_df_mbert.head(10))\n",
        "\n",
        "best_threshold_mbert = threshold_df_mbert.iloc[0][\"threshold\"]\n",
        "print(\"Best threshold for mBERT:\", best_threshold_mbert)\n",
        "print(threshold_df_mbert.iloc[0])"
      ],
