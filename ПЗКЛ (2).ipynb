      "cell_type": "markdown",
      "source": [
        "Взвешенная функция потерь дала прирост по метрикам и позволила модели увереннее выбирать класс Attack. Однако мы видим, что несколько отношений, для которых верно прдесказывался класс Support, перешли в класс Attack. Попробуем исправить это, подобрав threshold, т.е. порог модели для принятия решения о проставлении метки класса."
      ],
      "metadata": {
        "id": "2Mto_AyaqhM5"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "from scipy.special import softmax\n",
        "from sklearn.metrics import classification_report, precision_recall_fscore_support, accuracy_score\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "\n",
        "# Предсказания на validation\n",
        "val_output = trainer_weighted.predict(val_tok)\n",
        "\n",
        "y_val_true = val_output.label_ids\n",
        "val_probs = softmax(val_output.predictions, axis=1)\n",
        "\n",
        "attack_id = label2id[\"Attack\"]\n",
        "support_id = label2id[\"Support\"]\n",
        "\n",
        "attack_probs = val_probs[:, attack_id]\n",
        "\n",
        "results = []\n",
        "\n",
        "thresholds = np.arange(0.1, 0.91, 0.05)\n",
        "\n",
        "for threshold in thresholds:\n",
        "    y_val_pred = np.where(attack_probs >= threshold, attack_id, support_id)\n",
        "\n",
        "    precision_arr, recall_arr, f1_arr, _ = precision_recall_fscore_support(\n",
        "        y_val_true,\n",
        "        y_val_pred,\n",
        "        labels=[attack_id, support_id],\n",
        "        zero_division=0\n",
        "    )\n",
        "\n",
        "    acc = accuracy_score(y_val_true, y_val_pred)\n",
        "\n",
        "    results.append({\n",
        "        \"threshold\": threshold,\n",
        "        \"accuracy\": acc,\n",
        "        \"attack_precision\": precision_arr[0],\n",
        "        \"attack_recall\": recall_arr[0],\n",
        "        \"attack_f1\": f1_arr[0],\n",
        "        \"support_precision\": precision_arr[1],\n",
        "        \"support_recall\": recall_arr[1],\n",
        "        \"support_f1\": f1_arr[1],\n",
        "        \"macro_f1\": (f1_arr[0] + f1_arr[1]) / 2\n",
        "    })\n",
        "\n",
        "threshold_df = pd.DataFrame(results).sort_values(\"macro_f1\", ascending=False)\n",
        "\n",
        "print(\"Top thresholds on validation:\")\n",
        "display(threshold_df.head(10))"
      ],
