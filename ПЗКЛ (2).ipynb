      "cell_type": "markdown",
      "source": [
        "Выбираем новый threshold - 0,3. Обучим модель с новым threshold и оценим полученные результаты."
      ],
      "metadata": {
        "id": "jb1hyS7uqV56"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "best_threshold = 0.3"
      ],
      "metadata": {
        "id": "r7_3zlMQfY9n"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "from scipy.special import softmax\n",
        "from sklearn.metrics import classification_report, confusion_matrix, accuracy_score, precision_recall_fscore_support\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "\n",
        "# Предсказания на test\n",
        "test_output = trainer_weighted.predict(test_tok)\n",
        "\n",
        "y_true = test_output.label_ids\n",
        "test_probs = softmax(test_output.predictions, axis=1)\n",
        "\n",
        "attack_id = label2id[\"Attack\"]\n",
        "support_id = label2id[\"Support\"]\n",
        "\n",
        "# Применяем найденный threshold\n",
        "attack_probs_test = test_probs[:, attack_id]\n",
        "y_pred = np.where(attack_probs_test >= best_threshold, attack_id, support_id)\n",
        "\n",
        "# Текстовый отчёт\n",
        "print(f\"Threshold on test: {best_threshold:.2f}\\n\")\n",
        "\n",
        "print(\"Classification report with threshold:\\n\")\n",
        "print(classification_report(\n",
        "    y_true,\n",
        "    y_pred,\n",
        "    target_names=[id2label[i] for i in range(len(id2label))],\n",
        "    digits=4,\n",
        "    zero_division=0\n",
        "))\n",
        "\n",
        "# Отдельные метрики\n",
        "precision_arr, recall_arr, f1_arr, _ = precision_recall_fscore_support(\n",
        "    y_true,\n",
        "    y_pred,\n",
        "    labels=[attack_id, support_id],\n",
        "    zero_division=0\n",
        ")\n",
        "\n",
        "acc = accuracy_score(y_true, y_pred)\n",
        "macro_f1 = (f1_arr[0] + f1_arr[1]) / 2\n",
        "\n",
        "print(\"Summary metrics:\")\n",
        "print({\n",
        "    \"accuracy\": acc,\n",
        "    \"attack_precision\": precision_arr[0],\n",
        "    \"attack_recall\": recall_arr[0],\n",
        "    \"attack_f1\": f1_arr[0],\n",
        "    \"support_precision\": precision_arr[1],\n",
        "    \"support_recall\": recall_arr[1],\n",
        "    \"support_f1\": f1_arr[1],\n",
        "    \"macro_f1\": macro_f1\n",
        "})\n",
        "\n",
        "# Матрица ошибок\n",
        "cm = confusion_matrix(y_true, y_pred)\n",
        "\n",
        "class_names_ru = [\"Attack\", \"Support\"]\n",
        "\n",
        "plt.figure(figsize=(5, 4))\n",
        "sns.heatmap(\n",
        "    cm,\n",
        "    annot=True,\n",
        "    fmt=\"d\",\n",
        "    cmap=sns.light_palette(\"pink\", as_cmap=True),\n",
        "    xticklabels=class_names_ru,\n",
